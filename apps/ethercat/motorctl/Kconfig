#
# For a description of the syntax of this configuration file,
# see the file kconfig-language.txt in the NuttX tools repository.
#

config ETHERCAT_SOEM_MOTORCTL
	tristate "ETHERCAT SOEM MOTORCTL"
	default n
	---help---
		ETHERCAT SOEM MOTORCTL Program

if ETHERCAT_SOEM_MOTORCTL

config ETHERCAT_SOEM_MOTORCTL_PROGNAME
	string "Program name"
	default "motorctl"
	---help---
		This is the name of the program that will be used when the NSH ELF
		program is installed.

config ETHERCAT_SOEM_MOTORCTL_PRIORITY
	int "SOEM MOTORCTL Program task priority"
	default 128

config ETHERCAT_SOEM_MOTORCTL_STACKSIZE
	int "SOEM MOTORCTL Program stack size"
	default DEFAULT_TASK_STACKSIZE

endif
