if ARCH_CHIP_RK3568

menu "Rockchip RK3568 Peripheral Selection"

config RK3568_UART
	bool "UART 0"
	default n
	select UART0_SERIALDRIVER
	select ARCH_HAVE_SERIAL_TERMIOS
	---help---
		Select to enable support for UART0.

endmenu # Rockchip RK3568 Peripheral Selection

endif # ARCH_CHIP_RK3568
