{
	/*irqstate_t flags;*/
	
	/*flags = spin_lock_irqsave(&time_get_lock);*/
	
	while(is_in_arch_isr)
	{
	};	
	
	p_ectime->count = arm64_arch_timer_count();
	p_ectime->jiffies = jiffies;
	
	/*spin_unlock_irqrestore(&time_get_lock, flags);*/
