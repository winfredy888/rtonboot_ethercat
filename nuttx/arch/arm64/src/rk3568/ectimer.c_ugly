extern uint64_t g_cycle_per_tick;

static uint64_t ec_get_time_diff(struct ectime * p_ectime_start, struct ectime * p_ectime_end)
{
	uint64_t cnt;
	uint64_t jif_diff;
	
	if( (p_ectime_start->jiffies) == (p_ectime_end->jiffies) ) 
	{	
		cnt = (p_ectime_start->count) - (p_ectime_end->count);
		
		if( (p_ectime_start->count) <= (p_ectime_end->count) )
		{
			linux_printf("bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb\n");
		}		
		
		cnt *= 41;
		
		goto return_val;
	}
	else if( (p_ectime_end->jiffies) == ((p_ectime_start->jiffies) + 1) )
	{
		cnt = p_ectime_start->count;
		
		cnt += ( g_cycle_per_tick - (p_ectime_end->count) );
		
		cnt *= 41;
		
		goto return_val;
	}
	else
	{
		cnt = p_ectime_start->count;
		
		cnt += ( g_cycle_per_tick - (p_ectime_end->count) );
		
		jif_diff = (p_ectime_end->jiffies) - (p_ectime_start->jiffies) - 1;
		
		cnt += (jif_diff * g_cycle_per_tick);
		
		cnt *= 41;
		
		goto return_val;
	}
	
	return_val:
	
			return cnt;
}

uint64_t ec_get_time_diff_exec(struct ectime * p_ectime_start, struct ectime * p_ectime_end)
{
	uint64_t cnt;
	uint64_t jif_diff;
	
	if( (p_ectime_start->jiffies) == (p_ectime_end->jiffies) ) 
	{	
		cnt = (p_ectime_start->count) - (p_ectime_end->count);
		
		cnt *= 41;
		
		goto return_val;
	}
	else if( (p_ectime_end->jiffies) == ((p_ectime_start->jiffies) + 1) )
	{
		cnt = p_ectime_start->count;
		
		cnt += ( g_cycle_per_tick - (p_ectime_end->count) );
		
		cnt *= 41;
		
		goto return_val;
	}
	else
	{
		cnt = p_ectime_start->count;
		
		cnt += ( g_cycle_per_tick - (p_ectime_end->count) );
		
		jif_diff = (p_ectime_end->jiffies) - (p_ectime_start->jiffies) - 1;
		
		cnt += (jif_diff * g_cycle_per_tick);
		
		cnt *= 41;
		
		goto return_val;
	}
	
	return_val:
	
			if(cnt > 1000000)
			{
				cnt = 861;
			}	
	
			return cnt;
}


uint64_t ec_get_time_diff_period(struct ectime * p_ectime_start, struct ectime * p_ectime_end)
{
	uint64_t cnt;
	uint64_t jif_diff;
	
	if( (p_ectime_start->jiffies) == (p_ectime_end->jiffies) ) 
	{
		if( (p_ectime_start->count) < (p_ectime_end->count) )
		{
			return 1008436;
		}
			
		cnt = (p_ectime_start->count) - (p_ectime_end->count);
		
		cnt *= 41;
		
		goto return_period;
	}
	else if( (p_ectime_end->jiffies) == ((p_ectime_start->jiffies) + 1) )
	{
		cnt = p_ectime_start->count;
		
		cnt += ( g_cycle_per_tick - (p_ectime_end->count) );
		
		cnt *= 41;
		
		goto return_period;
	}
	else
	{
		cnt = p_ectime_start->count;
		
		cnt += ( g_cycle_per_tick - (p_ectime_end->count) );
		
		jif_diff = (p_ectime_end->jiffies) - (p_ectime_start->jiffies) - 1;
		
		cnt += (jif_diff * g_cycle_per_tick);
		
		cnt *= 41;
		
		goto return_period;
	}
	
	return_period:
	
	if(cnt > 1900000)
	{
		return 1006878;
	}	
	
	if(cnt < 1000000)
	{
		return 1007452;
	}
	
	return cnt;
}

uint64_t ec_get_calc_diff(struct ectime * p_ectime_start, struct ectime * p_ectime_end, uint64_t cycletime_ns)
{
	uint64_t real_ns = ec_get_time_diff(p_ectime_start, p_ectime_end);
	uint64_t diff_ns;
	
	if(real_ns >= cycletime_ns)
	{
		diff_ns = real_ns - cycletime_ns;
	}	
	else
	{
		diff_ns = real_ns;
		
		if(diff_ns > 900000)
		{
			diff_ns = cycletime_ns - real_ns;
		}	
	}	
	
	/*if(diff_ns > 980000)
	{
		return 1548;
	}*/
	
	return diff_ns;
}	

uint64_t ec_get_cur_time_ns(void)
{
	uint64_t cnt;
	uint64_t jif;
	
	cnt = arm64_arch_timer_count();
	jif = jiffies;
	
	cnt = g_cycle_per_tick - cnt;
	cnt += (jif * g_cycle_per_tick);
	
	cnt *= 41;
	
	return cnt;
}
