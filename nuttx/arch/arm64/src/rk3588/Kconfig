if ARCH_CHIP_RK3588

menu "Rockchip RK3588 Peripheral Selection"

config RK3588_UART
	bool "UART 0"
	default n
	select UART0_SERIALDRIVER
	select ARCH_HAVE_SERIAL_TERMIOS
	---help---
		Select to enable support for UART0.

endmenu # Rockchip RK3588 Peripheral Selection

endif # ARCH_CHIP_RK3588
